{
  "info": {
    "name": "LUMA — Waitlist Flow",
    "_postman_id": "luma-waitlist-2026",
    "description": "End-to-end requests for the LUMA waitlist feature. Import this file into Postman, then run the folder 'Waitlist E2E Scenario' to drive a full full-event → waitlist → promote → cancel flow. All auth tokens are captured automatically into collection variables via test scripts.\n\nSetup:\n1. Start backend at {{baseUrl}}.\n2. DataSeeder must have run (waitlist demo events exist).\n3. Open the collection variables, adjust baseUrl/emails if you changed seed values.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "eventName", "value": "Waitlist Demo (Free)" },
    { "key": "eventId", "value": "" },
    { "key": "tokenA", "value": "" },
    { "key": "tokenB", "value": "" },
    { "key": "tokenC", "value": "" },
    { "key": "regAId", "value": "" },
    { "key": "regBId", "value": "" },
    { "key": "regCId", "value": "" },
    { "key": "emailA", "value": "nguyenvan@gmail.com" },
    { "key": "emailB", "value": "tranbi@gmail.com" },
    { "key": "emailC", "value": "leminh@gmail.com" },
    { "key": "userPassword", "value": "user123" }
  ],
  "item": [
    {
      "name": "Waitlist E2E Scenario",
      "item": [
        {
          "name": "1. Login — User A",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{emailA}}\",\n  \"password\": \"{{userPassword}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('login A 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('tokenA', pm.response.json().data.accessToken);"
          ]}}]
        },
        {
          "name": "2. Login — User B",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{emailB}}\",\n  \"password\": \"{{userPassword}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('login B 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('tokenB', pm.response.json().data.accessToken);"
          ]}}]
        },
        {
          "name": "3. Login — User C",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{emailC}}\",\n  \"password\": \"{{userPassword}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('login C 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('tokenC', pm.response.json().data.accessToken);"
          ]}}]
        },
        {
          "name": "4. Find Waitlist Demo event",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": { "raw": "{{baseUrl}}/api/user/events/upcoming?size=100", "host": ["{{baseUrl}}"], "path": ["api", "user", "events", "upcoming"], "query": [{"key":"size","value":"100"}] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));",
            "const wanted = pm.collectionVariables.get('eventName');",
            "const match = pm.response.json().data.content.find(e => e.title === wanted);",
            "pm.expect(match, `event ${wanted} not found — run DataSeeder`).to.exist;",
            "pm.collectionVariables.set('eventId', match.id);",
            "pm.expect(match.capacity).to.eql(1);"
          ]}}]
        },
        {
          "name": "5. User A registers (claims the one seat)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenA}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/user/events/{{eventId}}/register", "host": ["{{baseUrl}}"], "path": ["api", "user", "events", "{{eventId}}", "register"] },
            "body": { "mode": "raw", "raw": "{\"quantity\": 1}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('register A 200', () => pm.response.to.have.status(200));",
            "const reg = pm.response.json().data;",
            "pm.expect(reg.status).to.not.eql('WAITING_LIST');",
            "pm.collectionVariables.set('regAId', reg.id);"
          ]}}]
        },
        {
          "name": "6. User B registers (event full → WAITING_LIST #1)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenB}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/user/events/{{eventId}}/register", "host": ["{{baseUrl}}"], "path": ["api", "user", "events", "{{eventId}}", "register"] },
            "body": { "mode": "raw", "raw": "{\"quantity\": 1}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('register B 200', () => pm.response.to.have.status(200));",
            "const reg = pm.response.json().data;",
            "pm.expect(reg.status, 'B must be WAITING_LIST').to.eql('WAITING_LIST');",
            "pm.expect(reg.waitingListPosition).to.eql(1);",
            "pm.collectionVariables.set('regBId', reg.id);"
          ]}}]
        },
        {
          "name": "7. User C registers (WAITING_LIST #2)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenC}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/user/events/{{eventId}}/register", "host": ["{{baseUrl}}"], "path": ["api", "user", "events", "{{eventId}}", "register"] },
            "body": { "mode": "raw", "raw": "{\"quantity\": 1}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('register C 200', () => pm.response.to.have.status(200));",
            "const reg = pm.response.json().data;",
            "pm.expect(reg.status).to.eql('WAITING_LIST');",
            "pm.expect(reg.waitingListPosition).to.eql(2);",
            "pm.collectionVariables.set('regCId', reg.id);"
          ]}}]
        },
        {
          "name": "8. User A cancels (triggers waitlist promotion)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": { "raw": "{{baseUrl}}/api/user/events/registrations/{{regAId}}", "host": ["{{baseUrl}}"], "path": ["api", "user", "events", "registrations", "{{regAId}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('cancel A 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "9. User B status after promotion",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenB}}" }],
            "url": { "raw": "{{baseUrl}}/api/user/events/{{eventId}}/registration-status", "host": ["{{baseUrl}}"], "path": ["api", "user", "events", "{{eventId}}", "registration-status"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));",
            "const data = pm.response.json().data;",
            "pm.expect(['APPROVED','PENDING','WAITING_LIST']).to.include(data.status);",
            "console.log('user B post-promotion status =', data.status);"
          ]}}]
        },
        {
          "name": "10. User B — pending waitlist offers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenB}}" }],
            "url": { "raw": "{{baseUrl}}/api/user/waitlist/offers", "host": ["{{baseUrl}}"], "path": ["api", "user", "waitlist", "offers"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));",
            "console.log('pending offers for B:', pm.response.json().data);"
          ]}}]
        },
        {
          "name": "11. User C status (position shifted down)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenC}}" }],
            "url": { "raw": "{{baseUrl}}/api/user/events/{{eventId}}/registration-status", "host": ["{{baseUrl}}"], "path": ["api", "user", "events", "{{eventId}}", "registration-status"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));",
            "const data = pm.response.json().data;",
            "console.log('user C position =', data.waitingListPosition);",
            "pm.expect([1, 2]).to.include(data.waitingListPosition);"
          ]}}]
        }
      ]
    },
    {
      "name": "Device Token (FCM)",
      "item": [
        {
          "name": "Register device token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenA}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/user/device-tokens", "host": ["{{baseUrl}}"], "path": ["api", "user", "device-tokens"] },
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"fake-fcm-token-for-testing\",\n  \"platform\": \"ANDROID\",\n  \"deviceModel\": \"Pixel 8\",\n  \"appVersion\": \"1.0.0\"\n}" }
          }
        },
        {
          "name": "Unregister device token",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": { "raw": "{{baseUrl}}/api/user/device-tokens?token=fake-fcm-token-for-testing", "host": ["{{baseUrl}}"], "path": ["api", "user", "device-tokens"], "query": [{"key":"token","value":"fake-fcm-token-for-testing"}] }
          }
        }
      ]
    },
    {
      "name": "Waitlist Offer actions",
      "item": [
        {
          "name": "Accept offer (paste offerId below)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenB}}" }],
            "url": { "raw": "{{baseUrl}}/api/user/waitlist/offers/:offerId/accept", "host": ["{{baseUrl}}"], "path": ["api", "user", "waitlist", "offers", ":offerId", "accept"], "variable": [{"key":"offerId","value":""}] }
          }
        },
        {
          "name": "Decline offer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenB}}" }],
            "url": { "raw": "{{baseUrl}}/api/user/waitlist/offers/:offerId/decline", "host": ["{{baseUrl}}"], "path": ["api", "user", "waitlist", "offers", ":offerId", "decline"], "variable": [{"key":"offerId","value":""}] }
          }
        }
      ]
    }
  ]
}
